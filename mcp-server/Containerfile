FROM python:3.14-slim@sha256:584e89d31009a79ae4d9e3ab2fba078524a6c0921cb2711d05e8bb5f628fc9b9

LABEL org.opencontainers.image.source="https://github.com/dadav/rhacs-manager" \
      org.opencontainers.image.description="RHACS Manager MCP Server" \
      org.opencontainers.image.licenses="MIT"

WORKDIR /app

ENV UV_CACHE_DIR=/tmp/uv-cache

# Install uv
COPY --from=ghcr.io/astral-sh/uv:latest /uv /uvx /usr/local/bin/

# Copy dependency files first for layer caching
COPY pyproject.toml uv.lock ./

# Install dependencies (no editable, no dev deps)
RUN uv sync --frozen --no-dev --no-editable && \
    chgrp -R 0 /tmp/uv-cache && chmod -R g=u /tmp/uv-cache

# Copy application code
COPY mcp_server/ ./mcp_server/

CMD ["uv", "run", "--no-dev", "--offline", "--no-sync", "python", "-m", "mcp_server"]
