FROM golang:1.25-alpine AS builder

WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download
COPY main.go .
RUN CGO_ENABLED=0 GOOS=linux go build -o /auth-header-injector .

FROM gcr.io/distroless/static:nonroot

LABEL org.opencontainers.image.source="https://github.com/dadav/rhacs-manager" \
      org.opencontainers.image.description="RHACS CVE Manager Auth Header Injector" \
      org.opencontainers.image.licenses="MIT"

COPY --from=builder /auth-header-injector /auth-header-injector
USER nonroot:nonroot
ENTRYPOINT ["/auth-header-injector"]
