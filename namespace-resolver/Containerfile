FROM golang:1.25-alpine AS builder

WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download
COPY main.go .
RUN CGO_ENABLED=0 GOOS=linux go build -o /namespace-resolver .

FROM gcr.io/distroless/static:nonroot
COPY --from=builder /namespace-resolver /namespace-resolver
USER nonroot:nonroot
ENTRYPOINT ["/namespace-resolver"]
