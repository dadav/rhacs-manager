FROM python:3.14-slim@sha256:584e89d31009a79ae4d9e3ab2fba078524a6c0921cb2711d05e8bb5f628fc9b9

LABEL org.opencontainers.image.source="https://github.com/dadav/rhacs-manager" \
      org.opencontainers.image.description="RHACS CVE Manager Backend" \
      org.opencontainers.image.licenses="MIT"

WORKDIR /app

ENV UV_CACHE_DIR=/tmp/uv-cache

# Install uv
COPY --from=ghcr.io/astral-sh/uv:latest /uv /uvx /usr/local/bin/

# Copy dependency files first for layer caching
COPY pyproject.toml uv.lock ./

# Install dependencies (no editable, no dev deps)
RUN uv sync --frozen --no-dev --no-editable && \
    chgrp -R 0 /tmp/uv-cache && chmod -R g=u /tmp/uv-cache

# Copy application code
COPY app/ ./app/
COPY alembic/ ./alembic/
COPY alembic.ini ./

# Run migrations then start server
CMD ["sh", "-c", "uv run --no-dev --offline --no-sync alembic upgrade head && uv run --no-dev --offline --no-sync uvicorn app.main:app --host 0.0.0.0 --port 8000"]
