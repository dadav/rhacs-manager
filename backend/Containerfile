FROM python:3.12-slim

LABEL org.opencontainers.image.source="https://github.com/dadav/rhacs-manager" \
      org.opencontainers.image.description="RHACS CVE Manager Backend" \
      org.opencontainers.image.licenses="MIT"

WORKDIR /app

# Install uv
COPY --from=ghcr.io/astral-sh/uv:latest /uv /uvx /usr/local/bin/

# Copy dependency files first for layer caching
COPY pyproject.toml uv.lock ./

# Install dependencies (no editable, no dev deps)
RUN uv sync --frozen --no-dev

# Copy application code
COPY app/ ./app/
COPY alembic/ ./alembic/
COPY alembic.ini ./

# Run migrations then start server
CMD ["sh", "-c", "uv run --offline alembic upgrade head && uv run --offline uvicorn app.main:app --host 0.0.0.0 --port 8000"]
