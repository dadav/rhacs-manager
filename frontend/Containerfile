# Build stage
FROM oven/bun:1 AS builder

WORKDIR /app

COPY package.json bun.lock ./
RUN bun install --frozen-lockfile

COPY . .
RUN bun run build

# Serve stage — spoke variant with API proxying to hub
FROM nginxinc/nginx-unprivileged:alpine

LABEL org.opencontainers.image.source="https://github.com/dadav/rhacs-manager" \
      org.opencontainers.image.description="RHACS CVE Manager Frontend (Spoke)" \
      org.opencontainers.image.licenses="MIT"

# Install envsubst (gettext package)
USER root
RUN apk add --no-cache gettext
USER 101

# Copy built SPA
COPY --from=builder /app/dist /usr/share/nginx/html

# Copy nginx template (envsubst will process it at startup)
COPY nginx.conf.spoke /etc/nginx/templates/default.conf.template

# Copy entrypoint script
COPY docker-entrypoint-spoke.sh /docker-entrypoint.sh
USER root
RUN chmod +x /docker-entrypoint.sh
USER 101

EXPOSE 8080

ENTRYPOINT ["/docker-entrypoint.sh"]
