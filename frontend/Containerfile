# Build stage
FROM oven/bun:1@sha256:b86c67b531d87b4db11470d9b2bd0c519b1976eee6fcd71634e73abfa6230d2e AS builder

WORKDIR /app

COPY package.json bun.lock ./
RUN bun install --frozen-lockfile

COPY . .
RUN bun run build

# Serve stage — spoke variant with API proxying to hub
FROM nginxinc/nginx-unprivileged:alpine@sha256:ccbac1a4c20a8b41c5dd1691bd91d63eda3b7989d643a33fd47841838519bfb9

LABEL org.opencontainers.image.source="https://github.com/dadav/rhacs-manager" \
      org.opencontainers.image.description="RHACS CVE Manager Frontend (Spoke)" \
      org.opencontainers.image.licenses="MIT"

# Install envsubst (gettext package)
USER root
RUN apk add --no-cache gettext
USER 101

# Copy built SPA
COPY --from=builder /app/dist /usr/share/nginx/html

# Copy nginx template (envsubst will process it at startup)
COPY nginx.conf.spoke /etc/nginx/templates/default.conf.template

# Copy entrypoint script
COPY docker-entrypoint-spoke.sh /docker-entrypoint.sh
USER root
RUN chmod +x /docker-entrypoint.sh
USER 101

EXPOSE 8080

ENTRYPOINT ["/docker-entrypoint.sh"]
